# ──────────────────────────────────────────
# Neon PostgreSQL (orders DB)
# Get from https://console.neon.tech → Connection string
# ──────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# ──────────────────────────────────────────
# Cashfree Payment Gateway
# Get from https://merchant.cashfree.com/merchants/pg/api-keys
# ──────────────────────────────────────────
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key
CASHFREE_ENV=sandbox

# ──────────────────────────────────────────
# Delhivery Shipping
# Get from https://app.delhivery.com → API > Webhooks & Tokens
# ──────────────────────────────────────────
DELHIVERY_API_TOKEN=your_delhivery_api_token
DELHIVERY_ENV=sandbox
DELHIVERY_PICKUP_NAME=Gray Cup Pickup

# ──────────────────────────────────────────
# Bucket0 S3 Storage (invoice files)
# Get from https://bucket0.com → S3 API → Create Key
# ──────────────────────────────────────────
BUCKET0_ACCESS_KEY_ID=your_bucket0_access_key_id
BUCKET0_SECRET_ACCESS_KEY=your_bucket0_secret_access_key
BUCKET0_BUCKET_NAME=your_bucket_name

# ──────────────────────────────────────────
# App Config
# ──────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3001
NEXT_PUBLIC_CASHFREE_MODE=sandbox

# ──────────────────────────────────────────
# Admin Auth
# ──────────────────────────────────────────
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=your_password
ADMIN_SESSION_SECRET=random_32_char_secret